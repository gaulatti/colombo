# App
PORT=8080

# Database (preferred names)
DATABASE_URL=jdbc:postgresql://localhost:5432/colombo
DATABASE_USER=colombo
DATABASE_PASSWORD=change-me

# Optional compatibility aliases (used as fallback if DATABASE_* are absent)
# DB_URL=jdbc:postgresql://localhost:5432/colombo
# DB_USERNAME=colombo
# DB_PASSWORD=change-me

# JPA / Flyway
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
